{
  "expo": {
    "name": "checkyapp",
    "slug": "checkyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "checkyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.keplerits.checkyapp",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af6a8f57-3ee8-40d5-af40-14dde3bd6b8b"
      }
    }
  }
}
